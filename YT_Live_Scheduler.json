    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert YouTube SEO strategist and gaming content writer.\n\nGenerate an SEO-optimized YouTube Title and Description for the game \"{{ $json['Game Name'] }}\".\n\nRequirements:\n- Mention \"Part {{ $json['Part Number'] }}\" naturally in both the title and description.\n- mention that the commentary is \"{{ $json['Commentary Language'] }}\"wiwithout using commentary word.\n- Create a title that is highly clickable, engaging, and optimized for YouTube search.\n- Keep the title under 100 characters (preferably 60–80 characters).\n- The description should:\n  - Start with a compelling 1–2 sentence introduction.\n  - Mention the game name, part number, and commentary language naturally.\n  - Briefly describe what viewers can expect in this episode.\n  - Encourage viewers to Like, Comment, Share, and Subscribe.\n  - Include a short call-to-action to turn on notifications.\n  - End with 10–15 relevant SEO keywords/hashtags.\n\nOutput ONLY in the following JSON format:\n\n{\n  \"title\": \"...\",\n  \"description\": \"...\"\n}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a Youtube SEO Assistant.\nProvide details carefully by referring global youtube"
        }
      },
